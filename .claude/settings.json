{
  "permissions": {
    "allow": [
      "Bash(python .claude/skills/**/scripts/*.py:*)",
      "Read(./.claude/skills/**)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*credentials*)",
      "Read(./**/*.pem)",
      "Read(./**/connections.toml)"
    ]
  }
}
